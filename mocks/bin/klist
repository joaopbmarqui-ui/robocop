#!/usr/bin/env python3
"""Fake klist for Dispatch development mode."""

import os
import sys
from datetime import datetime, timedelta
from pathlib import Path


def _ticket_ttl() -> int:
    state_root = Path(os.environ.get("DISPATCH_MOCK_STATE_DIR", "/tmp/dispatch_mock_state"))
    state_file = state_root / "klist_ttl"
    if state_file.exists():
        try:
            return int(state_file.read_text(encoding="utf-8").strip())
        except ValueError:
            return 0
    return int(os.environ.get("DISPATCH_MOCK_KLIST_TTL", "28800"))


def main() -> int:
    ttl = _ticket_ttl()
    if ttl <= 0:
        return 1
    if "-s" in sys.argv[1:]:
        return 0
    now = datetime.now()
    expires = now + timedelta(seconds=ttl)
    print("Ticket cache: FILE:/tmp/krb5cc_mock")
    print("Default principal: mock@EXAMPLE.COM")
    print("")
    print("Valid starting       Expires              Service principal")
    print(f"{now:%m/%d/%Y %H:%M:%S}  {expires:%m/%d/%Y %H:%M:%S}  krbtgt/EXAMPLE.COM@EXAMPLE.COM")
    return 0


if __name__ == "__main__":
    sys.exit(main())
